rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is logged in and their email matches the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "2455hannah@gmail.com";
    }

    match /{document=**} {
      allow read: if true; // Everyone can view the portfolio
      allow write: if isAdmin(); // Only Hannah can edit content
    }
  }
}
